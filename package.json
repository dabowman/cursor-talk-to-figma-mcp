{
  "name": "figmagent",
  "description": "Figmagent - AI Agent to Figma MCP",
  "version": "0.3.3",
  "module": "dist/server.js",
  "main": "dist/server.js",
  "bin": {
    "figmagent": "dist/server.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "scripts": {
    "start": "bun run dist/server.js",
    "socket": "bun run src/socket.ts",
    "setup": "./scripts/setup.sh",
    "build": "tsup",
    "build:watch": "tsup --watch",
    "dev": "bun run build:watch",
    "test": "bun test",
    "lint": "bunx biome lint .",
    "lint:fix": "bunx biome check --write .",
    "format": "bunx biome format --write .",
    "check": "bunx biome check .",
    "transcribe": "claude-code-transcripts all -s ~/.claude/projects/-Users-davidbowman-Github-cursor-talk-to-figma-mcp -o ~/Github/cursor-talk-to-figma-mcp/.claude/transcripts --include-agents"
  },
  "devDependencies": {
